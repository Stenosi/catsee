# ============================================================================
# CatSee — Variabili d'ambiente
# ============================================================================
# Copia questo file come `.env` e compila i valori.
# NON committare `.env` su Git (è in .gitignore).
# ============================================================================

# Database PostgreSQL (Neon)
# Trovi questo su Neon Dashboard → tuo progetto → Connection string
# Usa la connection string "pooled" per produzione, "direct" per migrations.
DATABASE_URL=postgresql://user:password@host.neon.tech/catsee?sslmode=require

# Auth.js
# Genera con: openssl rand -base64 32
AUTH_SECRET=your-random-secret-here

# Google OAuth (opzionale, per login con Google)
# Crea credenziali su https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Email provider per magic link (es. Resend, SendGrid)
# Resend (consigliato): https://resend.com — free tier 3000 email/mese
AUTH_RESEND_KEY=

# Email mittente per i magic link
EMAIL_FROM=noreply@catsee.app

# Cloudflare R2 (storage immagini)
# Crea bucket su https://dash.cloudflare.com/ → R2 → Create bucket
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=catsee
R2_PUBLIC_URL=https://pub-xxx.r2.dev

# Admin promotion (script di seed)
# Email dell'utente da promuovere ad admin al primo seed.
ADMIN_EMAIL=

# Cron job secret (R2 cleanup e altri job notturni)
# Genera con: openssl rand -base64 32
# Da aggiungere anche in Vercel → Settings → Environment Variables
CRON_SECRET=
